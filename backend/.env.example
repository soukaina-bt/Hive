# ─────────────────────────────────────────
#  E-Commerce Dashboard — Configuration
# ─────────────────────────────────────────

APP_NAME=E-Commerce Dashboard
APP_ENV=development

# Connexion Hive (VM Cloudera)
HIVE_HOST=192.168.47.129
HIVE_PORT=10000
HIVE_USERNAME=cloudera
HIVE_PASSWORD=cloudera
HIVE_DATABASE=ecommerce
HIVE_AUTH=NONE

# Gemini (Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Sécurité
APP_SECRET_KEY=change_me_in_production
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123

# Limites
MAX_QUERY_ROWS=2000
ALLOW_UNSAFE_QUERY_TYPES=false

# CORS
CORS_ORIGINS=http://localhost:3000
